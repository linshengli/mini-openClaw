# Qwen3 官方 OpenAI 兼容配置（DashScope）
# 国际站: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 中国站: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=YOUR_DASHSCOPE_API_KEY
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 主模型：Qwen3 Coder
OPENCLAW_MODEL=openai:qwen3-coder-plus

# 可选回退模型链（如需）
# OPENCLAW_MODELS=openai:qwen3-coder-plus,openai:qwen-plus
